/**
 * This script is intended to remove products that are not listed on tcgplayer.com to reduce the
 * processing load on the aggregation pipeline
 */
db.prices.aggregate([
    // Filter out cards that don't have a tcg_high_price, usually these products only have
    // data on another tcg market platform instead of tcgplayer
    {
      $match: { tcg_high_price: { $ne:  null }}
    },  
    {
    $sort: { date_updated: -1 }
  },
  // Find groups by set and get just the highest value card per set
  {
    $group: {
      _id: "$set_id",
      most_expensive: { 
        $top: {
          sortBy: { tcg_high_price: -1, date_updated: -1 },
          output: { price: "$tcg_high_price", product_id: "$product_id", printing: "$tcg_high_price_printing" }
          }
        }
      }
  },
  {
    $out: "prices_current_filtered"
  }
])